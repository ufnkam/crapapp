use std::env;
use std::fs;
use std::io::Write;
use std::path::Path;

use serde::{Deserialize, Serialize};

const SETUP_CONFIG: &str = "setup-config.json";
const SETUP_ICON: &str = "assets/install.ico";
const SETUP_MANIFEST: &str = r#"
<assembly xmlns="urn:schemas-microsoft-com:asm.v1" manifestVersion="1.0">
    <trustInfo xmlns="urn:schemas-microsoft-com:asm.v3">
        <security>
            <requestedPrivileges>
                <requestedExecutionLevel level="asInvoker" uiAccess="false" />
            </requestedPrivileges>
        </security>
    </trustInfo>
</assembly>
"#;

#[derive(Debug, Deserialize)]
struct BuildConfig {
    app_name: String,
    app_version: String,
    publisher: Option<String>,
    variables: Vec<String>,
    uninstaller_source: String,
    payload: Vec<BuildPayloadEntry>,
    icons: Vec<BuildIconEntry>,
}

#[derive(Debug, Deserialize)]
struct BuildPayloadEntry {
    source: String,
    destination: String,
    executable: bool,
}

#[derive(Clone, Debug, Deserialize, Serialize)]
struct BuildIconEntry {
    binary: String,
    #[serde(rename = "source")]
    #[serde(skip_serializing)]
    _source: String,
}

#[derive(Debug, Serialize)]
struct RuntimeConfig {
    app_name: String,
    app_version: String,
    publisher: Option<String>,
    variables: Vec<String>,
    payload: Vec<RuntimePayloadEntry>,
    icons: Vec<BuildIconEntry>,
}

#[derive(Debug, Serialize)]
struct RuntimePayloadEntry {
    destination: String,
    executable: bool,
    offset: usize,
    len: usize,
}

fn main() {
    println!("cargo:rerun-if-changed={SETUP_CONFIG}");
    println!("cargo:rerun-if-changed={SETUP_ICON}");
    println!("cargo:rerun-if-changed=../assets/install.ico");

    let out_dir = env::var("OUT_DIR").unwrap();
    let out_dir = Path::new(&out_dir);
    let config = build_config();
    let runtime_config = write_payload(&config, out_dir);

    fs::write(
        out_dir.join(SETUP_CONFIG),
        serde_json::to_vec_pretty(&runtime_config).unwrap(),
    )
    .unwrap();

    write_uninstaller(&config.uninstaller_source, out_dir);

    if env::var("CARGO_CFG_TARGET_OS").as_deref() == Ok("windows") {
        write_windows_resource();
    }
}

fn build_config() -> BuildConfig {
    match fs::read_to_string(SETUP_CONFIG) {
        Ok(config) => serde_json::from_str(&config).unwrap(),
        Err(error) if error.kind() == std::io::ErrorKind::NotFound => BuildConfig {
            app_name: "template-app".to_owned(),
            app_version: "0.0.0".to_owned(),
            publisher: None,
            variables: Vec::new(),
            uninstaller_source: String::new(),
            payload: Vec::new(),
            icons: Vec::new(),
        },
        Err(error) => panic!("failed to read {SETUP_CONFIG}: {error}"),
    }
}

fn write_payload(config: &BuildConfig, out_dir: &Path) -> RuntimeConfig {
    let mut payload_blob = fs::File::create(out_dir.join("payload.bin")).unwrap();
    let mut offset = 0usize;
    let mut payload = Vec::new();

    for file in &config.payload {
        let bytes = fs::read(&file.source).unwrap();
        payload_blob.write_all(&bytes).unwrap();

        payload.push(RuntimePayloadEntry {
            destination: file.destination.clone(),
            executable: file.executable,
            offset,
            len: bytes.len(),
        });

        offset += bytes.len();
    }

    RuntimeConfig {
        app_name: config.app_name.clone(),
        app_version: config.app_version.clone(),
        publisher: config.publisher.clone(),
        variables: config.variables.clone(),
        payload,
        icons: config.icons.clone(),
    }
}

fn write_uninstaller(source: &str, out_dir: &Path) {
    let destination = out_dir.join("uninstall.exe");

    if source.is_empty() {
        fs::write(destination, []).unwrap();
    } else {
        fs::copy(source, destination).unwrap();
    }
}

fn write_windows_resource() {
    let manifest_dir = env::var("CARGO_MANIFEST_DIR").unwrap();
    let generated_icon = Path::new(&manifest_dir).join(SETUP_ICON);
    let icon_path = if generated_icon.is_file() {
        generated_icon
    } else {
        Path::new(&manifest_dir).join("../assets/install.ico")
    };
    let icon_path = icon_path
        .to_str()
        .expect("installer icon path must be valid UTF-8");

    if !Path::new(icon_path).is_file() {
        panic!("installer icon does not exist: {icon_path}");
    }

    println!("cargo:warning=embedding installer icon from {icon_path}");

    let mut resource = winresource::WindowsResource::new();
    resource.set_icon(icon_path);
    resource.set_manifest(SETUP_MANIFEST);
    resource.compile().unwrap();
}
