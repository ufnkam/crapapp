[package]
name = "windows-installer-cli"
version = "0.1.0"
edition = "2024"

[dependencies]
clap = { version = "4.5.40", features = ["derive"] }
windows-installer-core = { path = "../windows-installer-core" }

[build-dependencies]
serde = { version = "1.0.219", features = ["derive"] }
serde_json = "1.0.150"
winresource = "0.1.23"

[[bin]]
name = "setup"
path = "src/setup.rs"

[[bin]]
name = "uninstall"
path = "src/uninstall.rs"

